{
  "name": "frp-prototype",
  "version": "1.0.0",
  "description": "File Routing and Processing (FRP) Management Prototype",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:client": "cd client && npm run build",
    "build:exe": "node scripts/build-exe.js",
    "migrate:mysql-to-sqlite": "node scripts/migrate-mysql-to-sqlite.js",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "echo 'Linting not configured yet'",
    "health": "curl -f http://localhost:3001/health || exit 1",
    "setup": "node scripts/setup-dev.js",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "client/build/**",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/better-sqlite3/prebuilds/**"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "release"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-validator": "^2.20.33",
    "@types/winston": "^2.4.4",
    "axios": "^1.10.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "winston": "^3.17.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.4",
    "@types/supertest": "^6.0.3",
    "@types/xml2js": "^0.4.14",
    "@vercel/ncc": "^0.38.4",
    "@yao-pkg/pkg": "^6.14.2",
    "jest": "^29.7.0",
    "mysql2": "^3.22.0",
    "pkg": "^5.8.1",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "frp",
    "email-monitoring",
    "powershell",
    "automation"
  ],
  "author": "FRP Team",
  "license": "ISC"
}
