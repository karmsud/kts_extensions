# FRP Prototype Environment Variables
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database Configuration (SQLite)
# Path to SQLite database file (can be a network share path)
DB_PATH=./database.db

# Logging Configuration
LOG_LEVEL=info

# Optional: Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
